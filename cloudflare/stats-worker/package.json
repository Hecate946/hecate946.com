{
  "name": "hecate-stats-worker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute hecate-stats --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute hecate-stats --local --file=./schema.sql",
    "db:export": "wrangler d1 export hecate-stats --remote --output=./hecate-stats-backup.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
