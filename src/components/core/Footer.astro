---
import '@/styles/footer.css';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="footer-copyright">© {year} Cyrus Asasi</p>

  <nav class="footer-links" aria-label="Contact and support links">
    <a
      class="footer-icon-link footer-icon-link--email"
      href="mailto:cyrusasasi@gmail.com"
      aria-label="Email Cyrus"
      data-label="Email"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <rect x="3.5" y="5.5" width="17" height="13" rx="2"></rect>
        <path d="m5 7 7 5.25L19 7"></path>
      </svg>
    </a>

    <a
      class="footer-icon-link footer-icon-link--github"
      href="https://github.com/Hecate946/"
      target="_blank"
      rel="me noopener noreferrer"
      aria-label="Cyrus on GitHub"
      data-label="GitHub"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M12 .7a11.3 11.3 0 0 0-3.57 22c.57.1.78-.25.78-.55v-2.17c-3.18.69-3.85-1.35-3.85-1.35-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.54-.29-5.21-1.27-5.21-5.65 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.45.11-3.03 0 0 .96-.31 3.11 1.17A10.8 10.8 0 0 1 12 6.9c.96 0 1.93.13 2.83.38 2.15-1.48 3.11-1.17 3.11-1.17.62 1.58.23 2.74.11 3.03.73.8 1.18 1.82 1.18 3.07 0 4.39-2.68 5.35-5.23 5.64.41.35.78 1.05.78 2.12v3.14c0 .3.21.66.79.55A11.3 11.3 0 0 0 12 .7Z"
        ></path>
      </svg>
    </a>

    <a
      class="footer-icon-link footer-icon-link--linkedin"
      href="https://www.linkedin.com/in/cyrus-asasi/"
      target="_blank"
      rel="me noopener noreferrer"
      aria-label="Cyrus on LinkedIn"
      data-label="LinkedIn"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M5.34 7.97A2.13 2.13 0 1 0 5.33 3.7a2.13 2.13 0 0 0 .01 4.27ZM3.5 20.3h3.67V9.25H3.5V20.3Zm5.7 0h3.67v-5.47c0-1.44.27-2.84 2.06-2.84 1.77 0 1.79 1.65 1.79 2.93v5.38h3.67v-6.07c0-2.98-.64-5.27-4.13-5.27-1.68 0-2.8.92-3.26 1.79h-.05v-1.5H9.2V20.3Z"
        ></path>
      </svg>
    </a>

    <a
      class="footer-icon-link footer-icon-link--coffee"
      href="https://buymeacoffee.com/hecate946"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Support Cyrus on Buy Me a Coffee"
      data-label="Buy me a coffee"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5.5 8h10.75v5.5A4.5 4.5 0 0 1 11.75 18h-1.5a4.75 4.75 0 0 1-4.75-4.75V8Z"></path>
        <path d="M16.25 10h1.1a2.6 2.6 0 0 1 0 5.2h-1.7"></path>
        <path d="M8.25 5.5c0-1 1-1.2 1-2.2M12.25 5.5c0-1 1-1.2 1-2.2"></path>
        <path d="M4.5 20h14"></path>
      </svg>
    </a>
  </nav>
</footer>
