---
import '@/styles/footer.css';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="footer-copyright">© {year} Cyrus Asasi</p>

  <nav class="footer-links" aria-label="Contact and support links">
    <a class="footer-icon-link footer-icon-link--email" href="mailto:cyrusasasi@gmail.com" aria-label="Email Cyrus" data-label="Gmail">
      <svg class="footer-service-logo footer-service-logo--gmail" viewBox="0 0 48 48" aria-hidden="true">
        <path fill="#4285F4" d="M6 14.6V38a4 4 0 0 0 4 4h5V21.35L6 14.6Z" />
        <path fill="#34A853" d="M33 21.35V42h5a4 4 0 0 0 4-4V14.6l-9 6.75Z" />
        <path fill="#EA4335" d="M33 12.1 24 18.85 15 12.1v9.25L24 28l9-6.65V12.1Z" />
        <path fill="#C5221F" d="M6 11.25v3.35l9 6.75V12.1l-4.8-3.6A2.63 2.63 0 0 0 6 11.25Z" />
        <path fill="#FBBC04" d="M42 11.25v3.35l-9 6.75V12.1l4.8-3.6a2.63 2.63 0 0 1 4.2 2.75Z" />
      </svg>
    </a>

    <a class="footer-icon-link footer-icon-link--github" href="https://github.com/Hecate946/" target="_blank" rel="me noopener noreferrer" aria-label="Cyrus on GitHub" data-label="GitHub">
      <svg class="footer-service-logo footer-service-logo--github" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.8a9.4 9.4 0 0 0-2.97 18.32c.47.09.64-.2.64-.45v-1.66c-2.62.57-3.17-1.11-3.17-1.11-.43-1.09-1.05-1.38-1.05-1.38-.86-.59.06-.58.06-.58.95.07 1.45.98 1.45.98.84 1.44 2.21 1.02 2.75.78.09-.61.33-1.03.6-1.27-2.09-.24-4.29-1.05-4.29-4.66 0-1.03.37-1.87.97-2.53-.1-.24-.42-1.2.09-2.5 0 0 .79-.25 2.58.97A8.95 8.95 0 0 1 12 7.4c.8 0 1.6.11 2.35.32 1.79-1.22 2.57-.97 2.57-.97.52 1.3.2 2.26.1 2.5.6.66.97 1.5.97 2.53 0 3.62-2.21 4.42-4.31 4.66.34.29.64.87.64 1.75v2.59c0 .25.17.55.65.45A9.4 9.4 0 0 0 12 2.8Z"/></svg>
    </a>

    <a class="footer-icon-link footer-icon-link--linkedin" href="https://www.linkedin.com/in/cyrus-asasi/" target="_blank" rel="me noopener noreferrer" aria-label="Cyrus on LinkedIn" data-label="LinkedIn">
      <svg class="footer-service-logo footer-service-logo--linkedin" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.3 8.1A1.8 1.8 0 1 1 6.3 4.5a1.8 1.8 0 0 1 0 3.6ZM4.75 9.55h3.1V19.5h-3.1V9.55Zm4.95 0h2.97v1.36h.04c.41-.78 1.43-1.61 2.94-1.61 3.14 0 3.72 2.07 3.72 4.76v5.44h-3.1v-4.82c0-1.15-.02-2.63-1.61-2.63-1.61 0-1.86 1.26-1.86 2.55v4.9H9.7V9.55Z"/></svg>
    </a>

    <a class="footer-icon-link footer-icon-link--coffee" href="https://buymeacoffee.com/hecate946" target="_blank" rel="noopener noreferrer" aria-label="Support Cyrus on Buy Me a Coffee" data-label="Buy me a coffee">
      <svg class="footer-service-logo footer-service-logo--coffee" viewBox="0 0 24 24" aria-hidden="true">
        <path class="coffee-cup-fill" d="M6.15 5.2h11.7l-.82 12.18a2.1 2.1 0 0 1-2.1 1.97H9.07a2.1 2.1 0 0 1-2.1-1.97L6.15 5.2Z" />
        <path class="coffee-cup-outline" d="M6.15 5.2h11.7l-.82 12.18a2.1 2.1 0 0 1-2.1 1.97H9.07a2.1 2.1 0 0 1-2.1-1.97L6.15 5.2ZM5.35 5.2h13.3M8.1 8.2h7.8" />
      </svg>
    </a>
  </nav>
</footer>
