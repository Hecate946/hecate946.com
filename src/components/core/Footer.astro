---
const year = new Date().getFullYear();

const footerLinks = [
  {
    label: 'email',
    href: 'mailto:cyrusasasi@gmail.com',
    external: false,
  },
  {
    label: 'github',
    href: 'https://github.com/Hecate946/',
    external: true,
  },
  {
    label: 'linkedin',
    href: 'https://www.linkedin.com/in/cyrus-asasi/',
    external: true,
  },
] as const;
---

<footer class="site-footer">
  <p class="footer-copyright">© {year} Cyrus Asasi</p>

  <nav class="footer-links" aria-label="contact links">
    {
      footerLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'me noopener noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</footer>
