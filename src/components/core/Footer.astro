---
import '@/styles/footer.css';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="footer-copyright">© {year} Cyrus Asasi</p>

  <nav class="footer-links" aria-label="Contact and support links">
    <a
      class="footer-icon-link footer-icon-link--email"
      href="mailto:cyrusasasi@gmail.com"
      aria-label="Email Cyrus"
      data-label="Email"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path class="footer-icon-mark" d="M6.25 8.25h11.5v7.5H6.25z"></path>
        <path class="footer-icon-detail" d="m6.8 8.9 5.2 3.85 5.2-3.85"></path>
      </svg>
    </a>

    <a
      class="footer-icon-link footer-icon-link--github"
      href="https://github.com/Hecate946/"
      target="_blank"
      rel="me noopener noreferrer"
      aria-label="Cyrus on GitHub"
      data-label="GitHub"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          class="footer-icon-logo"
          d="M12 5.35a6.75 6.75 0 0 0-2.13 13.15c.34.06.47-.15.47-.33v-1.29c-1.9.41-2.3-.81-2.3-.81-.31-.79-.76-1-.76-1-.62-.43.05-.42.05-.42.69.05 1.05.71 1.05.71.61 1.04 1.6.75 2 .57.06-.44.24-.75.44-.92-1.52-.17-3.12-.76-3.12-3.38 0-.75.27-1.36.71-1.84-.07-.17-.31-.87.07-1.81 0 0 .57-.19 1.86.7A6.45 6.45 0 0 1 12 8.5c.58 0 1.16.08 1.7.23 1.29-.89 1.86-.7 1.86-.7.38.94.14 1.64.07 1.81.44.48.71 1.09.71 1.84 0 2.63-1.61 3.21-3.13 3.38.25.21.47.63.47 1.27v1.88c0 .18.13.4.47.33A6.75 6.75 0 0 0 12 5.35Z"
        ></path>
      </svg>
    </a>

    <a
      class="footer-icon-link footer-icon-link--linkedin"
      href="https://www.linkedin.com/in/cyrus-asasi/"
      target="_blank"
      rel="me noopener noreferrer"
      aria-label="Cyrus on LinkedIn"
      data-label="LinkedIn"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle class="footer-icon-logo" cx="8.1" cy="8" r="1.35"></circle>
        <path class="footer-icon-logo" d="M6.95 10.3h2.3v7h-2.3zM10.85 10.3h2.2v.95h.03c.31-.58 1.06-1.2 2.18-1.2 2.33 0 2.76 1.53 2.76 3.53v3.72h-2.3V14c0-.79-.02-1.81-1.11-1.81-1.11 0-1.28.86-1.28 1.75v3.36h-2.3v-7Z"></path>
      </svg>
    </a>

    <a
      class="footer-icon-link footer-icon-link--coffee"
      href="https://buymeacoffee.com/hecate946"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Support Cyrus on Buy Me a Coffee"
      data-label="Buy me a coffee"
    >
      <img
        src="https://cdn.buymeacoffee.com/buttons/bmc-new-btn-logo.svg"
        alt=""
        aria-hidden="true"
      />
    </a>
  </nav>
</footer>
