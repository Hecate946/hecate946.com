---
import { headerNavigation, interests, siteConfig } from '@/config/site';
import { isCurrentPath, withBase } from '@/lib/paths';
import ColorModeToggle from '@/components/islands/ColorModeToggle.svelte';
import SeasonSelector from '@/components/islands/SeasonSelector.svelte';

const currentPath = Astro.url.pathname;
const interestPaths = interests.map((interest) => interest.href);

function isHeaderItemCurrent(label: string, href: string) {
  if (label === 'Interests') {
    return (
      isCurrentPath(currentPath, href) ||
      interestPaths.some((path) => isCurrentPath(currentPath, path))
    );
  }

  return isCurrentPath(currentPath, href);
}
---

<header class="site-header">
  <div class="header-grid">
    <a
      class="brand"
      href={withBase('/')}
      aria-label={`${siteConfig.name} home`}
      data-astro-prefetch
    >
      <span class="brand-full">{siteConfig.name}</span>
      <span class="brand-short" aria-hidden="true">Cyrus</span>
    </a>

    <nav class="primary-nav" aria-label="Primary navigation">
      <ul>
        {
          headerNavigation.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={
                  isHeaderItemCurrent(item.label, item.href)
                    ? 'page'
                    : undefined
                }
                data-astro-prefetch
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="mode-slot">
      <ColorModeToggle client:load />
    </div>

    <div class="seasons-slot">
      <SeasonSelector client:load />
    </div>
  </div>
</header>

<style is:global>
  .site-header {
    --nav-font-size: 1rem;
    --nav-font-weight: 600;
    --nav-underline-color: color-mix(
      in srgb,
      var(--header-accent) 72%,
      transparent
    );

    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-line);
    color: var(--header-text);
    font-family: var(--font-sans);
    view-transition-name: site-header;
  }

  /*
   * Keep the persistent header out of the page-level crossfade. This prevents
   * the old and new navbar snapshots from briefly stacking during navigation.
   */
  ::view-transition-group(site-header),
  ::view-transition-old(site-header),
  ::view-transition-new(site-header) {
    animation: none;
  }

  ::view-transition-old(site-header) {
    opacity: 0;
  }

  ::view-transition-new(site-header) {
    opacity: 1;
  }

  /* Do not animate from fallback theme values before ThemeBootstrap runs. */
  html:not([data-theme-ready='true']) .site-header,
  html:not([data-theme-ready='true']) .site-header * {
    transition: none !important;
  }

  /*
   * Desktop:
   * name | About / Interests / Stats | mode | seasons
   *
   * The navigation receives three fractional units and mode receives one,
   * making About, Interests, Stats, and the mode control exactly equal widths.
   */
  .header-grid {
    display: grid;
    grid-template-columns:
      clamp(10.5rem, 14vw, 13.5rem)
      minmax(0, 3fr)
      minmax(0, 1fr)
      clamp(10.75rem, 13vw, 12.25rem);
    width: 100%;
    height: 3rem;
    margin: 0;
    gap: 0;
  }

  .header-grid,
  .header-grid * {
    box-sizing: border-box;
  }

  .brand,
  .primary-nav,
  .mode-slot,
  .seasons-slot {
    min-width: 0;
  }

  .brand,
  .primary-nav a {
    color: var(--header-text);
    font-family: inherit;
    font-size: var(--nav-font-size);
    font-weight: var(--nav-font-weight);
    line-height: 1;
    text-align: center;
    text-decoration-line: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 0.11em;
    text-underline-offset: 0.34em;
    transition:
      color 140ms ease,
      text-decoration-color 140ms ease;
  }

  .brand {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: 0.75rem;
    border-right: 1px solid var(--header-line);
    background: transparent !important;
    letter-spacing: 0;
    text-decoration-skip-ink: auto;
  }

  .brand:hover,
  .brand:focus-visible,
  .primary-nav a:hover,
  .primary-nav a:focus-visible,
  .primary-nav a[aria-current='page'] {
    background: transparent !important;
    color: var(--header-text);
    text-decoration-color: var(--nav-underline-color);
  }

  .brand-short {
    display: none;
  }

  .primary-nav {
    padding: 0;
    margin: 0;
  }

  .primary-nav ul {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .primary-nav li {
    display: flex;
    min-width: 0;
    height: 100%;
    align-items: stretch;
  }

  .primary-nav li:not(:last-child) {
    border-right: 1px solid var(--header-line);
  }

  .primary-nav a {
    display: flex;
    width: 100%;
    min-width: 0;
    height: 100%;
    align-items: center;
    justify-content: center;
    padding-inline: 0.5rem;
    background: transparent !important;
  }

  .mode-slot,
  .seasons-slot {
    display: flex;
    min-width: 0;
    align-items: stretch;
    background: transparent;
  }

  .mode-slot {
    border-left: 1px solid var(--header-line);
    border-right: 1px solid var(--header-line);
  }

  .mode-slot > astro-island,
  .seasons-slot > astro-island {
    display: block;
    width: 100%;
    height: 100%;
    min-width: 0;
  }

  /*
   * Compact:
   * row 1: name (half) | mode (half) | seasons
   * row 2: About | Interests | Stats | seasons
   *
   * The header becomes taller only here, giving the 2 × 2 season selector
   * enough room while keeping both content rows exactly equal in height.
   */
  @media (max-width: 58rem) {
    .site-header {
      --nav-font-size: 0.94rem;
    }

    .header-grid {
      --compact-row-height: 2.4rem;

      grid-template-columns: repeat(6, minmax(0, 1fr)) 4.9rem;
      grid-template-rows: repeat(2, var(--compact-row-height));
      height: auto;
      min-height: 0;
    }

    .brand {
      grid-column: 1 / 4;
      grid-row: 1;
      padding-inline: 0.45rem;
      border-right: 1px solid var(--header-line);
    }

    .mode-slot {
      grid-column: 4 / 7;
      grid-row: 1;
      border: 0;
    }

    .primary-nav {
      grid-column: 1 / 7;
      grid-row: 2;
      border-top: 1px solid var(--header-line);
    }

    .primary-nav a {
      padding-inline: 0.25rem;
    }

    .seasons-slot {
      grid-column: 7;
      grid-row: 1 / 3;
      border-left: 1px solid var(--header-line);
    }
  }

  @media (max-width: 24rem) {
    .site-header {
      --nav-font-size: 0.88rem;
    }

    .brand-full {
      display: none;
    }

    .brand-short {
      display: inline;
    }
  }
</style>
