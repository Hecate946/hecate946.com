---
import { siteConfig } from '@/config/site';
import { headerNavigation, type HeaderNavItem } from '@/config/navigation';
import { isCurrentPath, withBase } from '@/lib/paths';

import ColorModeToggle from '@/components/islands/ColorModeToggle.svelte';
import CommandMenuButton from '@/components/islands/CommandMenuButton.svelte';
import SeasonSelector from '@/components/islands/SeasonSelector.svelte';

import '@/styles/layout.css';
import '@/styles/header.css';

const currentPath = Astro.url.pathname;

function isHeaderItemCurrent(item: HeaderNavItem) {
  return [item.href, ...(item.match ?? [])].some((path) =>
    isCurrentPath(currentPath, path),
  );
}
---

<header class="site-header" data-site-header data-scrolled="false">
  <div class="header-grid">
    <a
      class="brand"
      href={withBase('/')}
      aria-label={`${siteConfig.name} home`}
      data-astro-prefetch
    >
      <span class="brand-full">{siteConfig.name}</span>
      <span class="brand-short" aria-hidden="true">Cyrus</span>
    </a>

    <nav class="primary-nav" aria-label="Primary navigation">
      <ul>
        {
          headerNavigation.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={isHeaderItemCurrent(item) ? 'page' : undefined}
                data-astro-prefetch
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="command-slot header-region">
      <CommandMenuButton client:load />
    </div>

    <div class="mode-slot header-region">
      <ColorModeToggle client:load />
    </div>

    <div class="seasons-slot header-region">
      <SeasonSelector client:load />
    </div>
  </div>
</header>

<script>
  interface HeaderWindow extends Window {
    __siteHeaderScrollCleanup?: () => void;
  }

  function connectHeaderScrollState() {
    const headerWindow = window as HeaderWindow;
    headerWindow.__siteHeaderScrollCleanup?.();

    const header = document.querySelector<HTMLElement>('[data-site-header]');
    if (!header) return;

    const update = () => {
      header.dataset.scrolled = window.scrollY > 1 ? 'true' : 'false';
    };

    window.addEventListener('scroll', update, { passive: true });
    update();

    headerWindow.__siteHeaderScrollCleanup = () => {
      window.removeEventListener('scroll', update);
    };
  }

  connectHeaderScrollState();
  document.addEventListener('astro:page-load', connectHeaderScrollState);
</script>
