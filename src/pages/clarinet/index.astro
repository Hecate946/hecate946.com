---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import CardGrid from '@/components/ui/CardGrid.astro';
import ContentCard from '@/components/ui/ContentCard.astro';
import Section from '@/components/ui/Section.astro';

const entries = await getCollection(
  'music',
  ({ data }) => data.instrument === 'clarinet' && !data.draft,
);
---

<PageLayout
  eyebrow="Air & resonance"
  title="Clarinet"
  description="A performance archive designed to grow into interactive fingering, acoustics, score, recording, and repertoire experiences."
>
  <CardGrid>
    {
      entries.map((entry) => (
        <ContentCard
          title={entry.data.title}
          description={entry.data.description}
          eyebrow={entry.data.composer}
          tags={entry.data.tags}
          href={`/music/${entry.id}/`}
          symbol="♩"
        />
      ))
    }
  </CardGrid>

  <Section eyebrow="Future island" title="Air Room">
    <div class="placeholder surface">
      <strong>Interactive clarinet component boundary</strong>
      <p>
        Add a Svelte or Canvas component here for fingering, waveform,
        score-following, or breath visualization.
      </p>
    </div>
  </Section>
</PageLayout>

<style>
  .placeholder {
    padding: 1.5rem;
  }
  .placeholder p {
    margin-bottom: 0;
    color: var(--muted);
  }
</style>
