---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/paths';
import '@/styles/resume.css';

const resumeHref = withBase('/resumes/resume-placeholder.pdf');

const resumes = [
  {
    title: 'Software Engineering Resume',
    description: 'Education, work experience, and technical skills.',
  },
  {
    title: 'Clarinet Performance Resume',
    description: 'Education, performance experience, and awards.',
  },
] as const;
---

<BaseLayout
  title="Resume"
  description="Software engineering and music resumes for Cyrus Asasi."
>
  <section class="resume-page" aria-labelledby="resume-title">
    <header class="resume-heading">
      <h1 id="resume-title">Resume</h1>
    </header>

    <div class="resume-list">
      {
        resumes.map((resume) => (
          <article class="resume-entry">
            <div class="resume-copy">
              <h2>{resume.title}</h2>
              <p>{resume.description}</p>
            </div>

            <div class="resume-actions" aria-label={`${resume.title} actions`}>
              <a href={resumeHref} target="_blank" rel="noopener noreferrer">
                View PDF
              </a>
              <a href={resumeHref} download>
                Download
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
