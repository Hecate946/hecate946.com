---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/paths';
import '@/styles/resume.css';

const resumes = [
  {
    eyebrow: '01',
    title: 'Software Engineering Résumé',
    description:
      'Software development, interactive systems, web applications, and technical projects.',
    href: withBase('/resumes/software-engineering-resume-placeholder.pdf'),
  },
  {
    eyebrow: '02',
    title: 'Clarinet Performance CV',
    description:
      'Education, performance experience, ensembles, teachers, awards, and selected repertoire.',
    href: withBase('/resumes/clarinet-performance-cv-placeholder.pdf'),
  },
] as const;
---

<BaseLayout
  title="Resume"
  description="Software engineering résumé and clarinet performance CV for Cyrus Asasi."
>
  <section class="resume-page" aria-labelledby="resume-title">
    <header class="resume-heading">
      <h1 id="resume-title">Resume</h1>
      <p>Two disciplines. Pick the document that makes sense.</p>
    </header>

    <div class="resume-list">
      {
        resumes.map((resume) => (
          <article class="resume-entry">
            <span class="resume-number" aria-hidden="true">
              {resume.eyebrow}
            </span>

            <div class="resume-copy">
              <h2>{resume.title}</h2>
              <p>{resume.description}</p>
            </div>

            <div class="resume-actions" aria-label={`${resume.title} actions`}>
              <a href={resume.href} target="_blank" rel="noopener noreferrer">
                View PDF
              </a>
              <a href={resume.href} download>
                Download
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <p class="resume-note">
      These are temporary placeholder files. Replace the PDFs in
      <code>public/resumes/</code> while keeping the same filenames, or update the
      paths at the top of this page.
    </p>
  </section>
</BaseLayout>
