---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/contact.css';

const email = 'cyrusasasi@gmail.com';
const links = [
  {
    label: 'GitHub',
    detail: '@Hecate946',
    href: 'https://github.com/Hecate946/',
    icon: 'github',
  },
  {
    label: 'LinkedIn',
    detail: 'Cyrus Asasi',
    href: 'https://www.linkedin.com/in/cyrus-asasi/',
    icon: 'linkedin',
  },
  {
    label: 'Buy me a coffee',
    detail: 'Support the experiments',
    href: 'https://buymeacoffee.com/hecate946',
    icon: 'coffee',
  },
];
---

<BaseLayout
  title="Contact — Cyrus Asasi"
  description="Get in touch with Cyrus Asasi about software, music, collaborations, and creative projects."
>
  <div class="contact-page">
    <section class="contact-hero" aria-labelledby="contact-title">
      <h1 id="contact-title">Contact.</h1>
      <p class="contact-intro">Email is the simplest way to reach me.</p>
    </section>

    <section class="contact-switchboard" aria-label="Contact options">

      <article class="contact-terminal">
        <div class="terminal-topline">
          <span class="terminal-label">Direct line</span>
          <span class="availability"><i aria-hidden="true"></i> Usually replies within a few days</span>
        </div>

        <div class="email-row">
          <a href={`mailto:${email}`} class="email-address">{email}</a>
          <button class="copy-email" type="button" data-copy-email={email} aria-label="Copy email address">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="8" y="8" width="11" height="11" rx="2"></rect>
              <path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"></path>
            </svg>
            <span data-copy-label>Copy</span>
          </button>
        </div>

        <form class="message-builder" data-message-builder>
          <label>
            <span>What are we talking about?</span>
            <select name="subject">
              <option value="A software opportunity">Software opportunity</option>
              <option value="A music collaboration">Music collaboration</option>
              <option value="A creative project">Creative project</option>
              <option value="Just saying hello">Just saying hello</option>
            </select>
          </label>

          <label>
            <span>A quick note</span>
            <textarea name="message" rows="4" placeholder="Tell me a little about what you have in mind…"></textarea>
          </label>

          <button class="compose-button" type="submit">
            Compose email
            <span aria-hidden="true">↗︎</span>
          </button>
        </form>
      </article>

      <div class="contact-links">
        {links.map((link) => (
          <a class="contact-link-card" href={link.href} target="_blank" rel="me noopener noreferrer">
            <span class="contact-link-icon" aria-hidden="true">
              {link.icon === 'github' && (
                <svg viewBox="0 0 24 24"><path d="M12 .9A11.2 11.2 0 0 0 8.5 22.7c.56.1.77-.24.77-.54v-2.15c-3.13.68-3.79-1.33-3.79-1.33-.51-1.3-1.25-1.65-1.25-1.65-1.02-.7.08-.68.08-.68 1.13.08 1.73 1.16 1.73 1.16 1 1.72 2.64 1.23 3.29.94.1-.73.39-1.23.72-1.52-2.5-.28-5.13-1.25-5.13-5.57 0-1.23.44-2.23 1.16-3.03-.12-.28-.5-1.43.11-2.98 0 0 .94-.3 3.07 1.15A10.6 10.6 0 0 1 12 6.6c.95 0 1.9.13 2.79.38 2.12-1.46 3.07-1.15 3.07-1.15.61 1.55.22 2.7.11 2.98.72.79 1.16 1.8 1.16 3.03 0 4.33-2.64 5.27-5.15 5.56.4.35.77 1.04.77 2.09v3.09c0 .3.21.65.78.54A11.2 11.2 0 0 0 12 .9Z"></path></svg>
              )}
              {link.icon === 'linkedin' && (
                <svg viewBox="0 0 24 24"><path d="M5.3 8A2.2 2.2 0 1 0 5.3 3.6 2.2 2.2 0 0 0 5.3 8ZM3.4 20.4h3.8V9H3.4v11.4Zm5.9 0h3.8v-5.7c0-1.5.28-2.95 2.14-2.95 1.83 0 1.86 1.72 1.86 3.04v5.6h3.8v-6.3c0-3.1-.66-5.48-4.28-5.48-1.74 0-2.9.95-3.38 1.86h-.05V9H9.3v11.4Z"></path></svg>
              )}
              {link.icon === 'coffee' && (
                <svg viewBox="0 0 24 24"><path d="M5.5 8h10.7v5.4a4.5 4.5 0 0 1-4.5 4.5h-1.5a4.7 4.7 0 0 1-4.7-4.7V8Z"></path><path d="M16.2 10h1.1a2.6 2.6 0 0 1 0 5.2h-1.7M8.3 5.5c0-1 1-1.2 1-2.2M12.3 5.5c0-1 1-1.2 1-2.2M4.5 20h14"></path></svg>
              )}
            </span>
            <span class="contact-link-copy">
              <strong>{link.label}</strong>
              <small>{link.detail}</small>
            </span>
            <span class="contact-link-arrow" aria-hidden="true">↗︎</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  function connectContactPage() {
    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-email]');
    const builder = document.querySelector<HTMLFormElement>('[data-message-builder]');
    if (!copyButton || copyButton.dataset.connected === 'true') return;
    copyButton.dataset.connected = 'true';
    const contactEmail = copyButton.dataset.copyEmail;

    copyButton.addEventListener('click', async () => {
      const email = contactEmail;
      const label = copyButton.querySelector<HTMLElement>('[data-copy-label]');
      if (!email || !label) return;

      try {
        await navigator.clipboard.writeText(email);
        label.textContent = 'Copied';
        copyButton.dataset.copied = 'true';
        window.setTimeout(() => {
          label.textContent = 'Copy';
          delete copyButton.dataset.copied;
        }, 1800);
      } catch {
        window.location.href = `mailto:${email}`;
      }
    });

    builder?.addEventListener('submit', (event) => {
      event.preventDefault();
      const data = new FormData(builder);
      const subject = String(data.get('subject') ?? 'Hello');
      const message = String(data.get('message') ?? '');
      if (!contactEmail) return;
      window.location.href = `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(message)}`;
    });
  }

  connectContactPage();
  document.addEventListener('astro:page-load', connectContactPage);
</script>
