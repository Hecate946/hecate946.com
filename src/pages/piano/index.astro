---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import CardGrid from '@/components/ui/CardGrid.astro';
import ContentCard from '@/components/ui/ContentCard.astro';
import Section from '@/components/ui/Section.astro';

const entries = await getCollection(
  'music',
  ({ data }) => data.instrument === 'piano' && !data.draft,
);
---

<PageLayout
  eyebrow="Harmony & collaboration"
  title="Piano"
  description="Chamber projects, collaborative work, sight-reading growth, and repertoire presented as a navigable musical archive."
>
  <CardGrid>
    {
      entries.map((entry) => (
        <ContentCard
          title={entry.data.title}
          description={entry.data.description}
          eyebrow={entry.data.composer}
          tags={entry.data.tags}
          href={`/music/${entry.id}/`}
          symbol="⌨"
        />
      ))
    }
  </CardGrid>

  <Section eyebrow="Future island" title="Keyboard Archive">
    <div class="placeholder surface">
      <strong>Interactive piano component boundary</strong>
      <p>
        Add score-following, repertoire maps, keyboard interactions, or
        sight-reading progress without changing this page shell.
      </p>
    </div>
  </Section>
</PageLayout>

<style>
  .placeholder {
    padding: 1.5rem;
  }
  .placeholder p {
    margin-bottom: 0;
    color: var(--muted);
  }
</style>
