---
import BaseHead from '@/components/core/BaseHead.astro';
import '@/styles/not-found.css';

const videoId = '9390xDUuPuU';
const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&disablekb=1&fs=0&iv_load_policy=3&modestbranding=1&playsinline=1&rel=0&enablejsapi=1`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="404" description="this page is not here." />
  </head>
  <body class="error-page">
    <div class="error-noise" aria-hidden="true"></div>

    <main class="error-stage">
      <h1 class="error-code" aria-label="error 404">404</h1>

      <div class="error-video-shell">
        <iframe
          id="error-video"
          src={embedUrl}
          title="404 page video"
          allow="autoplay; encrypted-media; picture-in-picture"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </main>

    <button class="error-sound" type="button" aria-pressed="false">
      sound off
    </button>

    <script is:inline>
      const frame = document.querySelector('#error-video');
      const soundButton = document.querySelector('.error-sound');
      let soundEnabled = false;

      function sendPlayerCommand(command) {
        frame?.contentWindow?.postMessage(
          JSON.stringify({
            event: 'command',
            func: command,
            args: [],
          }),
          '*',
        );
      }

      soundButton?.addEventListener('click', () => {
        soundEnabled = !soundEnabled;
        sendPlayerCommand(soundEnabled ? 'unMute' : 'mute');
        soundButton.textContent = soundEnabled ? 'sound on' : 'sound off';
        soundButton.setAttribute('aria-pressed', String(soundEnabled));
      });
    </script>
  </body>
</html>
