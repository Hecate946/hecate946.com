---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ForceNetwork from '@/components/graphs/ForceNetwork.svelte';
import { homeNetworkLinks, homeNetworkNodes } from '@/data/home-network';
import '@/styles/home.css';
---

<BaseLayout
  title="Cyrus Asasi — Software Engineer & Classical Musician"
  description="The portfolio of Cyrus Asasi, software engineer and classical musician."
>
  <main class="minimal-home">
    <section class="minimal-hero" aria-labelledby="home-title">
      <header class="minimal-intro">
        <h1 id="home-title">Cyrus Asasi</h1>
        <p>Software engineer and classical musician</p>
      </header>

      <div class="home-network-stage">
        <ForceNetwork
          client:load
          nodes={homeNetworkNodes}
          links={homeNetworkLinks}
          centerNodeId="home"
          idPrefix="home-network"
          ariaLabel="Portfolio navigation centered on Cyrus Asasi"
          height="min(67svh, 43rem)"
          settings={{
            layout: 'radial',
            radialRadius: 0.325,
            radialStartAngle: -Math.PI / 2,
            entranceRadius: 0,
            chargeStrength: -190,
            anchorStrength: 0.18,
            centerAnchorStrength: 0.42,
            collisionPadding: 18,
            linkStrength: 0.2,
          }}
        />
      </div>
    </section>
  </main>
</BaseLayout>
