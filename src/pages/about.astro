---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/paths';
import '@/styles/about.css';
---

<BaseLayout
  title="About"
  description="About Cyrus Asasi, software engineer and classical musician."
>
