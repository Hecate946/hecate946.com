---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import CardGrid from '@/components/ui/CardGrid.astro';
import ContentCard from '@/components/ui/ContentCard.astro';

const projects = (
  await getCollection('projects', ({ data }) => !data.draft)
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<PageLayout
  eyebrow="Systems & experiments"
  title="Computer Science"
  description="Projects should expose not only what was built, but how the system works, what tradeoffs were made, and what changed after testing."
>
  <CardGrid>
    {
      projects.map((project) => (
        <ContentCard
          title={project.data.title}
          description={project.data.description}
          eyebrow={project.data.status}
          tags={project.data.technologies}
          href={`/code/${project.id}/`}
          symbol="</>"
        />
      ))
    }
  </CardGrid>
</PageLayout>
