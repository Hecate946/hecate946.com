---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import CardGrid from '@/components/ui/CardGrid.astro';
import ContentCard from '@/components/ui/ContentCard.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<PageLayout
  eyebrow="Field notes"
  title="Writing"
  description="Short essays and project notes that connect the portfolio's disciplines and document how the site itself evolves."
>
  <CardGrid>
    {
      notes.map((note) => (
        <ContentCard
          title={note.data.title}
          description={note.data.description}
          eyebrow={note.data.category}
          tags={note.data.tags}
          href={`/notes/${note.id}/`}
          symbol="¶"
        />
      ))
    }
  </CardGrid>
</PageLayout>
