---
import PageLayout from '@/layouts/PageLayout.astro';
import CardGrid from '@/components/ui/CardGrid.astro';
import ContentCard from '@/components/ui/ContentCard.astro';
import { interests } from '@/config/site';
---

<PageLayout
  eyebrow="Five disciplines"
  title="Interests"
  description="Explore the different parts of my work and life—from software and performance to strategy and movement. Each section will eventually have its own visual language and interactive experiments."
>
  <CardGrid>
    {interests.map((interest) => <ContentCard {...interest} />)}
  </CardGrid>
</PageLayout>

<style>
  :global(.card-grid) {
    padding-bottom: var(--space-8);
  }
</style>
