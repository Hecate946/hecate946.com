---
import BaseHead from '@/components/core/BaseHead.astro';
import Footer from '@/components/core/Footer.astro';
import Header from '@/components/core/Header.astro';
import SkipLink from '@/components/core/SkipLink.astro';
import ThemeBootstrap from '@/components/core/ThemeBootstrap.astro';
import CommandPalette from '@/components/islands/CommandPalette.svelte';
import SeasonalShower from '@/components/islands/SeasonalShower.svelte';
import { headerNavigation } from '@/config/navigation';
import { navigation } from '@/config/site';
import { withBase } from '@/lib/paths';
import '@/styles/global.css';
import '@/styles/footer.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;

const commandItems = Array.from(
  new Map(
    [...headerNavigation, ...navigation].map((item) => [
      item.href,
      {
        label: item.label,
        href: withBase(item.href),
      },
    ]),
  ).values(),
);
---

<!doctype html>
<html
  lang="en"
  data-season="summer"
  data-season-preference="auto"
  data-theme="light"
>
  <head>
    <ThemeBootstrap />
    <BaseHead {title} {description} {image} />
  </head>
  <body>
    <SkipLink />
    <SeasonalShower client:load transition:persist="seasonal-shower" />
    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    <CommandPalette client:load items={commandItems} />
  </body>
</html>
